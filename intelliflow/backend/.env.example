OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
GROQ_API_KEY=gsk_replace-me
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=intelliflow

# Generation — primary LLM is Groq's llama-3.3-70b-versatile (OpenAI-compatible API)
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_FALLBACK_MODEL=claude-sonnet-4-6

# Retrieval
LLM_REWRITER_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
RAG_GENERATOR_INPUT_TOKEN_CAP=15000

# Storage
CHROMA_PERSIST_DIR=./.chroma
KB_ROOT=./knowledge_base
