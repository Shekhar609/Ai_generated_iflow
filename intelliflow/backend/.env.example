OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=intelliflow

# Generation
LLM_MODEL=gpt-4-turbo
LLM_FALLBACK_MODEL=claude-sonnet-4-6

# Retrieval
